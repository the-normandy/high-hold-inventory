{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "High Hold Storehouse",
  "version": "1.0.3",
  "identifier": "com.high-hold.storehouse",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFRDZGODVBQUQwRDAyNDkKUldSSkFnMnRXdmpXdmd0QTZHZW9hemd2TUZLZHlncDJYS3FzNkk4dnZPN29yeUxqc3ZSZU5TbXQK",
      "endpoints": [
        "https://github.com/the-normandy/high-hold-inventory/releases/latest/download/latest.json"
      ]
    }
  },
  "build": {
    "frontendDist": "../dist/high-hold-inventory/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "ng serve",
    "beforeBuildCommand": "ng build --configuration production"
  },
  "app": {
    "windows": [
      {
        "title": "High Hold Storehouse",
        "width": 1400,
        "height": 850,
        "resizable": true,
        "center": true,
        "minWidth": 1000,
        "minHeight": 650,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
